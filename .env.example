# ---- HTTP server ----
# Bind to localhost only (the service exposes WhatsApp control with no auth).
HOST=127.0.0.1
PORT=3000

# ---- Storage ----
# Everything persistent lives under DATA_DIR:
#   <DATA_DIR>/profiles.db        SQLite profile metadata
#   <DATA_DIR>/sessions/          whatsapp-web.js LocalAuth session files (one folder per profile)
DATA_DIR=./data

# ---- Anti-ban: sending behaviour ----
# A random delay between MIN and MAX (milliseconds) is applied before every send,
# after the typing indicator. Keep these non-trivial — see the warning in the README.
MESSAGE_DELAY_MIN_MS=800
MESSAGE_DELAY_MAX_MS=2500
# Send a "typing…" presence update before each message.
TYPING_SIMULATION=true

# ---- Uploads ----
# Max accepted file size for multipart media uploads, in megabytes.
MAX_UPLOAD_MB=32

# ---- QR / profile creation ----
# When creating a profile, how long (ms) POST /profiles waits for the first QR
# (or a restored session) before returning. Poll GET /profiles/:id/qr afterwards.
QR_WAIT_MS=25000

# ---- Reconnect backoff ----
RECONNECT_BASE_MS=2000
RECONNECT_MAX_MS=60000
RECONNECT_MAX_RETRIES=10

# ---- Logging ----
# pino level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
# Pretty-print logs for local dev (true) or emit JSON (false).
LOG_PRETTY=true

# ---- Puppeteer / Chromium (optional) ----
# Point at a system Chrome/Chromium if you don't want the bundled download.
# PUPPETEER_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
